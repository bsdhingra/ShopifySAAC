      }

      #bd-carousel-{{ section.id }}.bd-carousel--mobile-large .bd-carousel__slide {
        min-height: 38rem;
      }

      #bd-carousel-{{ section.id }}.bd-carousel--mobile-adapt .bd-carousel__slide {
        min-height: auto;
        aspect-ratio: var(--bd-carousel-mobile-aspect);
      }

      #bd-carousel-{{ section.id }} .bd-carousel__content-wrap {
        padding: 1.2rem 1.2rem var(--bd-carousel-mobile-content-bottom-padding);
