      #bd-carousel-{{ section.id }} .bd-carousel__button {
        font-size: var(--bd-carousel-mobile-button-font-size);
        min-height: var(--bd-carousel-mobile-button-min-height);
        padding: 0.7rem var(--bd-carousel-mobile-button-horizontal-padding);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.16),
          0 6px 14px rgba(15, 23, 42, calc(0.12 * var(--bd-carousel-mobile-button-shadow-strength))),
          0 2px 5px rgba(15, 23, 42, calc(0.08 * var(--bd-carousel-mobile-button-shadow-strength)));
      }

      {% if section.settings.mobile_cta_layout == 'below' %}
        #bd-carousel-{{ section.id }} .bd-carousel__actions {
          position: static;
          margin-top: var(--bd-carousel-mobile-cta-spacing);
          margin-bottom: 0;
          display: flex;
          justify-content: center;
          width: 100%;
        }
      {% endif %}

      {% if section.settings.mobile_cta_layout == 'above' %}
        #bd-carousel-{{ section.id }} .bd-carousel__actions {
