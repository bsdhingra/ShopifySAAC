{%- liquid
  assign bd_carousel_section_label = section.settings.accessibility_label | strip
  if bd_carousel_section_label == blank
    assign bd_carousel_section_label = 'Premium carousel'
  endif

  assign bd_carousel_desktop_height = section.settings.desktop_height | default: 'large'
  assign bd_carousel_mobile_height = section.settings.mobile_height | default: 'medium'
  assign bd_carousel_image_fit = section.settings.image_fit | default: 'cover'
  assign bd_carousel_section_width = section.settings.section_max_width | default: 'full'
  assign bd_carousel_use_page_width = false
  assign bd_carousel_use_custom_width = false
  if bd_carousel_section_width == 'page'
    assign bd_carousel_use_page_width = true
  elsif bd_carousel_section_width == 'custom'
    assign bd_carousel_use_custom_width = true
  endif
  assign bd_carousel_content_width = section.settings.text_container_width | default: 'medium'
  assign bd_carousel_overlay_style = section.settings.overlay_style | default: 'gradient'
  assign bd_carousel_global_overlay_opacity = section.settings.global_overlay_opacity | default: 45

  assign bd_carousel_desktop_hidden = false
  assign bd_carousel_mobile_hidden = false
  if section.settings.hide_on_desktop
    assign bd_carousel_desktop_hidden = true
  endif
  if section.settings.hide_on_mobile
    assign bd_carousel_mobile_hidden = true
  endif

  assign bd_carousel_motion_ms = 500
  if section.settings.enable_subtle_animation == false
    assign bd_carousel_motion_ms = 420
  endif

  assign bd_carousel_autoplay_speed = section.settings.autoplay_speed | default: 5
  if bd_carousel_autoplay_speed < 2
    assign bd_carousel_autoplay_speed = 2
  endif

  assign bd_carousel_first_block = section.blocks.first
  assign bd_carousel_first_desktop_aspect = 1.7778
  assign bd_carousel_first_mobile_aspect = 1.25
  if bd_carousel_first_block
    if bd_carousel_first_block.settings.desktop_image and bd_carousel_first_block.settings.desktop_image.aspect_ratio
      assign bd_carousel_first_desktop_aspect = bd_carousel_first_block.settings.desktop_image.aspect_ratio
    endif
    if bd_carousel_first_block.settings.mobile_image and bd_carousel_first_block.settings.mobile_image.aspect_ratio
      assign bd_carousel_first_mobile_aspect = bd_carousel_first_block.settings.mobile_image.aspect_ratio
    else
      assign bd_carousel_first_mobile_aspect = bd_carousel_first_desktop_aspect
    endif
  endif
-%}

<section
  id="bd-carousel-{{ section.id }}"
  class="bd-carousel bd-carousel--desktop-{{ bd_carousel_desktop_height }} bd-carousel--mobile-{{ bd_carousel_mobile_height }}{% if bd_carousel_desktop_hidden %} bd-carousel--hide-desktop{% endif %}{% if bd_carousel_mobile_hidden %} bd-carousel--hide-mobile{% endif %}"
  data-bd-carousel-section
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ bd_carousel_autoplay_speed | times: 1000 }}"
  data-show-arrows="{{ section.settings.enable_arrows }}"
  data-show-dots="{{ section.settings.enable_dots }}"
  data-motion-ms="{{ bd_carousel_motion_ms }}"
  data-subtle-animation="{{ section.settings.enable_subtle_animation }}"
  role="region"
  aria-roledescription="carousel"
  aria-label="{{ bd_carousel_section_label | escape }}"
  style="
    --bd-carousel-padding-top: {{ section.settings.padding_top }}px;
    --bd-carousel-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bd-carousel-motion-ms: {{ bd_carousel_motion_ms }}ms;
    --bd-carousel-content-max-width: {{ section.settings.content_max_width }}px;
    --bd-carousel-global-overlay-opacity: {{ bd_carousel_global_overlay_opacity | divided_by: 100.0 }};
    --bd-carousel-mobile-gutter: {{ section.settings.mobile_side_padding }}px;
    --bd-carousel-desktop-gutter: {{ section.settings.desktop_side_padding }}px;
    --bd-carousel-section-max-width: {{ section.settings.custom_section_width }}px;
    --bd-carousel-surface: rgb(var(--color-background));
    --bd-carousel-desktop-aspect: {{ bd_carousel_first_desktop_aspect }};
    --bd-carousel-mobile-aspect: {{ bd_carousel_first_mobile_aspect }};
    --bd-carousel-arrow-bg: {{ section.settings.arrow_background_color }};
    --bd-carousel-arrow-text: {{ section.settings.arrow_icon_color }};
    --bd-carousel-arrow-border: {{ section.settings.arrow_border_color }};
    --bd-carousel-dot-bg: {{ section.settings.dot_color }};
    --bd-carousel-dot-active-bg: {{ section.settings.dot_active_color }};
    --bd-carousel-button-font-size: {{ section.settings.button_font_size }}px;
    --bd-carousel-button-min-height: {{ section.settings.button_height }}px;
    --bd-carousel-mobile-button-font-size: {{ section.settings.mobile_button_font_size }}px;
    --bd-carousel-mobile-button-min-height: {{ section.settings.mobile_button_height }}px;
    --bd-carousel-mobile-button-horizontal-padding: {{ section.settings.mobile_button_horizontal_padding }}px;
    --bd-carousel-mobile-button-shadow-strength: {{ section.settings.mobile_button_shadow_strength | divided_by: 100.0 }};
    --bd-carousel-mobile-button-x: {{ section.settings.mobile_button_x }};
    --bd-carousel-mobile-button-y: {{ section.settings.mobile_button_y }};
    --bd-carousel-mobile-cta-spacing: {{ section.settings.mobile_cta_spacing }}px;
    --bd-carousel-desktop-controls-bottom: {{ section.settings.desktop_controls_bottom_offset }}px;
    --bd-carousel-desktop-content-bottom-padding: {{ section.settings.desktop_content_bottom_padding }}px;
    --bd-carousel-mobile-controls-bottom: {{ section.settings.mobile_controls_bottom_offset }}px;
    --bd-carousel-mobile-content-bottom-padding: {{ section.settings.mobile_content_bottom_padding }}px;
  "
>
  <style>
    #bd-carousel-{{ section.id }} {
      position: relative;
      padding-top: var(--bd-carousel-padding-top);
      padding-bottom: var(--bd-carousel-padding-bottom);
      color: rgb(var(--color-foreground));
    }

    #bd-carousel-{{ section.id }}.bd-carousel--hide-desktop {
      display: block;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__shell {
      position: relative;
      width: 100%;
      box-sizing: border-box;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__shell--full {
      padding-left: var(--bd-carousel-mobile-gutter);
      padding-right: var(--bd-carousel-mobile-gutter);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__shell--page {
      padding-left: 0;
      padding-right: 0;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__shell--custom {
      max-width: calc(var(--bd-carousel-section-max-width) + (var(--bd-carousel-mobile-gutter) * 2));
      margin: 0 auto;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__frame {
      position: relative;
      overflow: hidden;
      border-radius: 2rem;
      background: var(--bd-carousel-surface);
      box-shadow:
        inset 0 0 0 1px rgba(var(--color-foreground), 0.04),
        0 28px 60px rgba(15, 23, 42, 0.16);
      isolation: isolate;
      transform: translateZ(0);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__viewport {
      overflow: hidden;
      position: relative;
      background: inherit;
      backface-visibility: hidden;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__track {
      display: flex;
      will-change: transform;
      transition: transform var(--bd-carousel-motion-ms) cubic-bezier(0.22, 1, 0.36, 1);
      transform: translateX(0%);
      backface-visibility: hidden;
      transform-style: preserve-3d;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__slide {
      position: relative;
      flex: 0 0 100%;
      min-width: 100%;
      min-height: clamp(24rem, 70vh, 56rem);
      display: flex;
      align-items: stretch;
      background: var(--bd-carousel-surface);
      backface-visibility: hidden;
      transform: translateZ(0);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__media-wrap {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: {{ bd_carousel_image_fit }};
      object-position: center;
      display: block;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__media--mobile {
      display: none;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__placeholder {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.78), transparent 0 24%),
        linear-gradient(130deg, #dbeafe, #ede9fe 46%, #f8fafc);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__placeholder::before,
    #bd-carousel-{{ section.id }} .bd-carousel__placeholder::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      filter: blur(4px);
      opacity: 0.7;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__placeholder::before {
      width: 22rem;
      height: 22rem;
      right: -5rem;
      top: -4rem;
      background: rgba(191, 219, 254, 0.8);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__placeholder::after {
      width: 16rem;
      height: 16rem;
      left: -2rem;
      bottom: -3rem;
      background: rgba(216, 180, 254, 0.42);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: var(--bd-carousel-slide-overlay-opacity, var(--bd-carousel-global-overlay-opacity));
      background: transparent;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__overlay--solid {
      background: rgba(17, 24, 39, 1);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__overlay--gradient {
      background:
        linear-gradient(120deg, rgba(15, 23, 42, 0.92) 0%, rgba(15, 23, 42, 0.42) 44%, rgba(15, 23, 42, 0.14) 100%);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap {
      position: relative;
      z-index: 2;
      width: 100%;
      min-height: inherit;
      display: grid;
      padding:
        clamp(1.5rem, 3vw, 2.75rem)
        clamp(1.5rem, 3vw, 2.75rem)
        var(--bd-carousel-desktop-content-bottom-padding);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--top {
      align-items: start;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--middle {
      align-items: center;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--bottom {
      align-items: end;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--left {
      justify-items: start;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--center {
      justify-items: center;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--right {
      justify-items: end;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--freeform {
      display: block;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content {
      width: min(100%, var(--bd-carousel-content-max-width));
      max-width: 100%;
      display: grid;
      gap: 0.9rem;
      text-wrap: balance;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content-wrap--freeform .bd-carousel__content {
      position: absolute;
      top: calc(var(--bd-carousel-content-y-desktop, 50) * 1%);
      left: calc(var(--bd-carousel-content-x-desktop, 50) * 1%);
      transform: translate(
        calc(var(--bd-carousel-content-x-desktop, 50) * -1%),
        calc(var(--bd-carousel-content-y-desktop, 50) * -1%)
      );
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content--narrow {
      max-width: min(38rem, var(--bd-carousel-content-max-width));
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content--medium {
      max-width: min(48rem, var(--bd-carousel-content-max-width));
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content--wide {
      max-width: min(62rem, var(--bd-carousel-content-max-width));
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content[data-align="left"] {
      text-align: left;
      justify-items: start;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content[data-align="center"] {
      text-align: center;
      justify-items: center;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__content[data-align="right"] {
      text-align: right;
      justify-items: end;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__eyebrow {
      margin: 0;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.92;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__heading {
      margin: 0;
      line-height: 0.96;
      font-weight: 700;
      letter-spacing: -0.05em;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__heading--small {
      font-size: clamp(2rem, 4vw, 3rem);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__heading--medium {
      font-size: clamp(2.5rem, 5.1vw, 4.35rem);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__heading--large {
      font-size: clamp(3rem, 6vw, 5.5rem);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__heading--xlarge {
      font-size: clamp(3.4rem, 7vw, 6.6rem);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__body {
      margin: 0;
      max-width: 58ch;
      font-size: clamp(1rem, 1.25vw, 1.16rem);
      line-height: 1.65;
      opacity: 0.94;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: var(--bd-carousel-button-min-height);
      padding: 0.85rem 1.4rem;
      border-radius: 999px;
      border: 1px solid var(--bd-carousel-button-border, transparent);
      background: color-mix(in srgb, var(--bd-carousel-button-bg, #111827) var(--bd-carousel-button-opacity, 100%), transparent);
      color: var(--bd-carousel-button-text, #ffffff);
      font-size: var(--bd-carousel-button-font-size);
      font-weight: 600;
      line-height: 1;
      text-decoration: none;
      isolation: isolate;
      transition:
        transform 180ms ease,
        background-color 180ms ease,
        border-color 180ms ease,
        color 180ms ease,
        box-shadow 180ms ease;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.18),
        0 8px 20px rgba(15, 23, 42, 0.12),
        0 2px 6px rgba(15, 23, 42, 0.08);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button::before {
      content: "";
      position: absolute;
      inset: 1px;
      border-radius: inherit;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0));
      opacity: 0.75;
      pointer-events: none;
      z-index: -1;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button:hover,
    #bd-carousel-{{ section.id }} .bd-carousel__button:focus-visible {
      transform: translateY(-1px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.2),
        0 12px 28px rgba(15, 23, 42, 0.16),
        0 4px 10px rgba(15, 23, 42, 0.1);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button.bd-carousel__button--hover-fill:hover,
    #bd-carousel-{{ section.id }} .bd-carousel__button.bd-carousel__button--hover-fill:focus-visible {
      background: var(--bd-carousel-button-hover-bg, var(--bd-carousel-button-bg, #111827));
      border-color: var(--bd-carousel-button-hover-border, var(--bd-carousel-button-border, transparent));
      color: var(--bd-carousel-button-hover-text, var(--bd-carousel-button-text, #ffffff));
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button:focus-visible,
    #bd-carousel-{{ section.id }} .bd-carousel__nav-button:focus-visible,
    #bd-carousel-{{ section.id }} .bd-carousel__dot:focus-visible,
    #bd-carousel-{{ section.id }} .bd-carousel__slide-link:focus-visible {
      outline: 2px solid rgba(255, 255, 255, 0.95);
      outline-offset: 2px;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button--secondary {
      background: color-mix(in srgb, var(--bd-carousel-button-bg, #ffffff) 18%, transparent);
      backdrop-filter: blur(10px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.22),
        0 8px 18px rgba(15, 23, 42, 0.1);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__button--outline {
      background: transparent;
      backdrop-filter: blur(8px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 6px 16px rgba(15, 23, 42, 0.08);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__controls {
      position: absolute;
      inset-inline: clamp(1rem, 2vw, 1.5rem);
      bottom: var(--bd-carousel-desktop-controls-bottom);
      z-index: 3;
      min-height: 3rem;
      pointer-events: none;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__arrows,
    #bd-carousel-{{ section.id }} .bd-carousel__dots {
      position: absolute;
      bottom: 0;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      pointer-events: auto;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__arrows--left,
    #bd-carousel-{{ section.id }} .bd-carousel__dots--left {
      left: 0;
      justify-content: flex-start;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__arrows--center,
    #bd-carousel-{{ section.id }} .bd-carousel__dots--center {
      left: 50%;
      transform: translateX(-50%);
      justify-content: center;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__arrows--right,
    #bd-carousel-{{ section.id }} .bd-carousel__dots--right {
      right: 0;
      justify-content: flex-end;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__nav-button {
      width: 3rem;
      height: 3rem;
      border-radius: 999px;
      border: 1px solid var(--bd-carousel-arrow-border, rgba(255, 255, 255, 0.22));
      background: var(--bd-carousel-arrow-bg, rgba(255, 255, 255, 0.12));
      color: var(--bd-carousel-arrow-text, #fff);
      backdrop-filter: blur(12px);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__nav-button:hover,
    #bd-carousel-{{ section.id }} .bd-carousel__nav-button:focus-visible {
      transform: translateY(-1px);
      background: color-mix(in srgb, var(--bd-carousel-arrow-bg, rgba(255, 255, 255, 0.12)) 88%, white);
      border-color: color-mix(in srgb, var(--bd-carousel-arrow-border, rgba(255, 255, 255, 0.22)) 88%, white);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__nav-button svg {
      width: 1rem;
      height: 1rem;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__nav-button--prev svg {
      transform: rotate(180deg);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__dot {
      width: 0.72rem;
      height: 0.72rem;
      border-radius: 999px;
      border: 0;
      padding: 0;
      background: var(--bd-carousel-dot-bg, rgba(255, 255, 255, 0.34));
      cursor: pointer;
      transition: transform 180ms ease, background-color 180ms ease, width 180ms ease;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__dot[aria-current="true"] {
      width: 2rem;
      background: var(--bd-carousel-dot-active-bg, rgba(255, 255, 255, 0.92));
    }

    #bd-carousel-{{ section.id }} .bd-carousel__dot:hover,
    #bd-carousel-{{ section.id }} .bd-carousel__dot:focus-visible {
      background: var(--bd-carousel-dot-active-bg, rgba(255, 255, 255, 0.82));
      transform: scale(1.05);
    }

    #bd-carousel-{{ section.id }} .bd-carousel__status {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__slide-link {
      position: absolute;
      inset: 0;
      z-index: 2;
    }

    #bd-carousel-{{ section.id }} .bd-carousel__slide[aria-hidden="true"] .bd-carousel__slide-link {
      pointer-events: none;
    }

    {% if section.settings.enable_subtle_animation %}
      #bd-carousel-{{ section.id }} .bd-carousel__content > * {
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity calc(var(--bd-carousel-motion-ms) + 120ms) ease,
          transform calc(var(--bd-carousel-motion-ms) + 120ms) ease;
      }

      #bd-carousel-{{ section.id }} .bd-carousel__slide.is-active .bd-carousel__content > * {
        opacity: 1;
        transform: translateY(0);
      }

      #bd-carousel-{{ section.id }} .bd-carousel__slide.is-active .bd-carousel__content > *:nth-child(2) {
        transition-delay: 60ms;
      }

      #bd-carousel-{{ section.id }} .bd-carousel__slide.is-active .bd-carousel__content > *:nth-child(3) {
        transition-delay: 110ms;
      }

      #bd-carousel-{{ section.id }} .bd-carousel__slide.is-active .bd-carousel__content > *:nth-child(4) {
        transition-delay: 160ms;
      }

      #bd-carousel-{{ section.id }} .bd-carousel__content > .bd-carousel__actions,
      #bd-carousel-{{ section.id }} .bd-carousel__slide.is-active .bd-carousel__content > .bd-carousel__actions {
        opacity: 1;
        transform: none;
        transition: none;
      }
    {% endif %}

    #bd-carousel-{{ section.id }}.bd-carousel--desktop-small .bd-carousel__slide {
      min-height: clamp(22rem, 50vh, 34rem);
    }

    #bd-carousel-{{ section.id }}.bd-carousel--desktop-medium .bd-carousel__slide {
      min-height: clamp(28rem, 64vh, 42rem);
    }

    #bd-carousel-{{ section.id }}.bd-carousel--desktop-large .bd-carousel__slide {
      min-height: clamp(34rem, 80vh, 52rem);
    }

    #bd-carousel-{{ section.id }}.bd-carousel--desktop-full .bd-carousel__slide {
      min-height: min(92vh, 58rem);
    }

    #bd-carousel-{{ section.id }}.bd-carousel--desktop-adapt .bd-carousel__slide {
      min-height: auto;
      aspect-ratio: var(--bd-carousel-desktop-aspect);
