              assign bd_carousel_text_alignment = block.settings.text_alignment | default: 'left'
              assign bd_carousel_vertical_position = block.settings.vertical_position | default: 'middle'
              assign bd_carousel_horizontal_position = block.settings.horizontal_position | default: 'left'
              assign bd_carousel_freeform_position = false
              assign bd_carousel_content_x_desktop = 50
              assign bd_carousel_content_y_desktop = 50
              assign bd_carousel_content_x_mobile = 50
              assign bd_carousel_content_y_mobile = 50
              assign bd_carousel_button_text = block.settings.button_text_color
              assign bd_carousel_button_background = block.settings.button_background_color
              assign bd_carousel_button_border = block.settings.button_border_color
              assign bd_carousel_button_opacity = block.settings.button_background_opacity
              assign bd_carousel_button_hover_fill = block.settings.enable_button_hover_fill
              assign bd_carousel_button_hover_background = block.settings.button_hover_background_color
              assign bd_carousel_button_hover_border = block.settings.button_hover_border_color
              assign bd_carousel_button_hover_text = block.settings.button_hover_text_color
              assign bd_carousel_button_1_label = block.settings.button_1_label
              assign bd_carousel_button_1_link = block.settings.button_1_link
              assign bd_carousel_button_2_label = block.settings.button_2_label
              assign bd_carousel_button_2_link = block.settings.button_2_link

              if section.settings.use_shared_buttons
                assign bd_carousel_button_style = section.settings.shared_button_style | default: 'primary'
                assign bd_carousel_button_text = section.settings.shared_button_text_color
                assign bd_carousel_button_background = section.settings.shared_button_background_color
                assign bd_carousel_button_border = section.settings.shared_button_border_color
                assign bd_carousel_button_opacity = section.settings.shared_button_background_opacity
                assign bd_carousel_button_hover_fill = section.settings.enable_shared_button_hover_fill
                assign bd_carousel_button_hover_background = section.settings.shared_button_hover_background_color
                assign bd_carousel_button_hover_border = section.settings.shared_button_hover_border_color
                assign bd_carousel_button_hover_text = section.settings.shared_button_hover_text_color
                assign bd_carousel_button_1_label = section.settings.shared_button_1_label
                assign bd_carousel_button_1_link = section.settings.shared_button_1_link
                assign bd_carousel_button_2_label = section.settings.shared_button_2_label
                assign bd_carousel_button_2_link = section.settings.shared_button_2_link
              endif

              if section.settings.use_shared_content_alignment
                assign bd_carousel_text_alignment = section.settings.shared_text_alignment | default: 'left'
                assign bd_carousel_vertical_position = section.settings.shared_vertical_position | default: 'middle'
                assign bd_carousel_horizontal_position = section.settings.shared_horizontal_position | default: 'left'

                if section.settings.enable_shared_freeform_position
                  assign bd_carousel_freeform_position = true
                  assign bd_carousel_content_x_desktop = section.settings.shared_content_x_desktop
                  assign bd_carousel_content_y_desktop = section.settings.shared_content_y_desktop

                  if section.settings.use_same_shared_position_on_mobile
                    assign bd_carousel_content_x_mobile = section.settings.shared_content_x_desktop
                    assign bd_carousel_content_y_mobile = section.settings.shared_content_y_desktop
                  else
                    assign bd_carousel_content_x_mobile = section.settings.shared_content_x_mobile
                    assign bd_carousel_content_y_mobile = section.settings.shared_content_y_mobile
                  endif
                endif
              endif

              assign bd_carousel_has_primary_button = false
              assign bd_carousel_has_secondary_button = false
              if bd_carousel_button_1_label != blank
                assign bd_carousel_has_primary_button = true
              endif
              if bd_carousel_button_2_label != blank
                assign bd_carousel_has_secondary_button = true
              endif

              assign bd_carousel_allow_full_slide_link = false
              if block.settings.slide_link != blank and bd_carousel_has_primary_button == false and bd_carousel_has_secondary_button == false
                assign bd_carousel_allow_full_slide_link = true
              endif

              assign bd_carousel_image_alt = block.settings.image_alt | strip
              if bd_carousel_image_alt == blank and block.settings.desktop_image != blank and block.settings.desktop_image.alt != blank
                assign bd_carousel_image_alt = block.settings.desktop_image.alt
              endif

              assign bd_carousel_media_loading = 'lazy'
              assign bd_carousel_media_fetch = 'auto'
              assign bd_carousel_desktop_media_class = 'bd-carousel__media bd-carousel__media--desktop'
              if block.settings.mobile_image != blank
                assign bd_carousel_desktop_media_class = bd_carousel_desktop_media_class | append: ' has-mobile'
              endif
              if forloop.first
                assign bd_carousel_media_loading = 'eager'
                assign bd_carousel_media_fetch = 'high'
              endif
            -%}
            <article
              class="bd-carousel__slide{% if forloop.first %} is-active{% endif %}"
              id="bd-carousel-slide-{{ section.id }}-{{ forloop.index }}"
              data-bd-carousel-slide
              data-slide-index="{{ forloop.index0 }}"
              aria-roledescription="slide"
              aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
              {{ block.shopify_attributes }}
              style="--bd-carousel-slide-overlay-opacity: {{ bd_carousel_slide_overlay_opacity | divided_by: 100.0 }};"
            >
              <div class="bd-carousel__media-wrap">
                {%- if block.settings.desktop_image != blank -%}
                  {{
                    block.settings.desktop_image
                    | image_url: width: 3840
                    | image_tag:
                      class: bd_carousel_desktop_media_class,
                      widths: '750, 1100, 1500, 2000, 3000, 3840',
                      sizes: '100vw',
                      loading: bd_carousel_media_loading,
                      fetchpriority: bd_carousel_media_fetch,
                      alt: bd_carousel_image_alt
                  }}
                {%- else -%}
                  <div class="bd-carousel__placeholder" aria-hidden="true"></div>
                {%- endif -%}

                {%- if bd_carousel_mobile_image != blank -%}
                  {{
                    bd_carousel_mobile_image
                    | image_url: width: 1600
                    | image_tag:
                      class: 'bd-carousel__media bd-carousel__media--mobile',
                      widths: '375, 550, 750, 1100, 1500, 1600',
                      sizes: '100vw',
                      loading: bd_carousel_media_loading,
                      alt: bd_carousel_image_alt
                  }}
                {%- endif -%}
                <div
                  class="bd-carousel__overlay{% if bd_carousel_overlay_style != 'none' %} bd-carousel__overlay--{{ bd_carousel_overlay_style }}{% endif %}"
                  aria-hidden="true"
                ></div>
              </div>

              {%- if bd_carousel_allow_full_slide_link -%}
                <a
                  class="bd-carousel__slide-link"
                  href="{{ block.settings.slide_link }}"
                  aria-label="{{ block.settings.heading | default: block.settings.eyebrow | default: 'Open slide link' | escape }}"
                ></a>
              {%- endif -%}

              <div
                class="bd-carousel__content-wrap bd-carousel__content-wrap--{{ bd_carousel_vertical_position }} bd-carousel__content-wrap--{{ bd_carousel_horizontal_position }}{% if bd_carousel_freeform_position %} bd-carousel__content-wrap--freeform{% endif %}"
                {% if bd_carousel_freeform_position %}
                  style="
                    --bd-carousel-content-x-desktop: {{ bd_carousel_content_x_desktop }};
                    --bd-carousel-content-y-desktop: {{ bd_carousel_content_y_desktop }};
                    --bd-carousel-content-x-mobile: {{ bd_carousel_content_x_mobile }};
                    --bd-carousel-content-y-mobile: {{ bd_carousel_content_y_mobile }};
                  "
                {% endif %}
              >
                <div
                  class="bd-carousel__content bd-carousel__content--{{ bd_carousel_content_width }}"
                  data-align="{{ bd_carousel_text_alignment }}"
                  style="
                    color: {{ block.settings.text_color }};
                    --bd-carousel-button-text: {{ bd_carousel_button_text }};
                    --bd-carousel-button-bg: {{ bd_carousel_button_background }};
                    --bd-carousel-button-border: {{ bd_carousel_button_border }};
                    --bd-carousel-button-opacity: {{ bd_carousel_button_opacity }}%;
                    --bd-carousel-button-hover-bg: {{ bd_carousel_button_hover_background }};
                    --bd-carousel-button-hover-border: {{ bd_carousel_button_hover_border }};
                    --bd-carousel-button-hover-text: {{ bd_carousel_button_hover_text }};
                  "
                >
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="bd-carousel__eyebrow">{{ block.settings.eyebrow | escape }}</p>
                  {%- endif -%}

                  {%- if block.settings.heading != blank -%}
                    <h2 class="bd-carousel__heading bd-carousel__heading--{{ block.settings.heading_size }}">
                      {{ block.settings.heading }}
                    </h2>
                  {%- endif -%}

                  {%- if block.settings.body != blank -%}
                    <div class="bd-carousel__body rte">
                      {{ block.settings.body }}
                    </div>
                  {%- endif -%}

                  {%- if bd_carousel_has_primary_button or bd_carousel_has_secondary_button -%}
                    <div class="bd-carousel__actions{% if section.settings.mobile_button_position_mode == 'custom' %} bd-carousel__actions--mobile-custom{% endif %}">
                      {%- if bd_carousel_has_primary_button -%}
                        <a
                          class="bd-carousel__button bd-carousel__button--{{ bd_carousel_button_style }}{% if bd_carousel_button_hover_fill %} bd-carousel__button--hover-fill{% endif %}"
                          {% if bd_carousel_button_1_link != blank %}
                            href="{{ bd_carousel_button_1_link }}"
                          {% else %}
                            role="link"
                            aria-disabled="true"
                          {% endif %}
                        >
                          {{ bd_carousel_button_1_label | escape }}
                        </a>
                      {%- endif -%}

                      {%- if bd_carousel_has_secondary_button -%}
                        <a
                          class="bd-carousel__button bd-carousel__button--{{ bd_carousel_button_style }}{% if bd_carousel_button_hover_fill %} bd-carousel__button--hover-fill{% endif %}"
                          {% if bd_carousel_button_2_link != blank %}
                            href="{{ bd_carousel_button_2_link }}"
                          {% else %}
                            role="link"
                            aria-disabled="true"
                          {% endif %}
                        >
                          {{ bd_carousel_button_2_label | escape }}
                        </a>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </article>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="bd-carousel__controls">
          {%- if section.settings.enable_arrows -%}
            <div class="bd-carousel__arrows bd-carousel__arrows--{{ section.settings.arrow_position }}">
              <button
                type="button"
                class="bd-carousel__nav-button bd-carousel__nav-button--prev"
                data-bd-carousel-prev
                aria-label="Previous slide"
              >
                <svg viewBox="0 0 10 10" aria-hidden="true" focusable="false">
                  <path d="M2 5h6M5 2l3 3-3 3" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4"></path>
                </svg>
              </button>
              <button
                type="button"
                class="bd-carousel__nav-button bd-carousel__nav-button--next"
                data-bd-carousel-next
                aria-label="Next slide"
              >
                <svg viewBox="0 0 10 10" aria-hidden="true" focusable="false">
                  <path d="M2 5h6M5 2l3 3-3 3" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4"></path>
                </svg>
              </button>
            </div>
          {%- endif -%}

          {%- if section.settings.enable_dots -%}
            <div class="bd-carousel__dots bd-carousel__dots--{{ section.settings.dot_position }}" data-bd-carousel-dots>
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  class="bd-carousel__dot"
                  data-bd-carousel-dot
                  data-slide-index="{{ forloop.index0 }}"
                  aria-label="Go to slide {{ forloop.index }}"
                  aria-controls="bd-carousel-slide-{{ section.id }}-{{ forloop.index }}"
                  aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <p class="bd-carousel__status" aria-live="polite" aria-atomic="true" data-bd-carousel-status>
        Slide 1 of {{ section.blocks.size }}
      </p>
