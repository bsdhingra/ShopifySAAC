  </div>

  <script>
    (function() {
      var root = document.getElementById('bd-carousel-{{ section.id }}');
      if (!root || root.dataset.bdCarouselReady === 'true') return;
      root.dataset.bdCarouselReady = 'true';

      var viewport = root.querySelector('[data-bd-carousel-viewport]');
      var track = root.querySelector('[data-bd-carousel-track]');
      var realSlides = Array.prototype.slice.call(root.querySelectorAll('[data-bd-carousel-slide]'));
      if (!viewport || !track || realSlides.length === 0) return;

      var prevButton = root.querySelector('[data-bd-carousel-prev]');
      var nextButton = root.querySelector('[data-bd-carousel-next]');
      var dots = Array.prototype.slice.call(root.querySelectorAll('[data-bd-carousel-dot]'));
      var status = root.querySelector('[data-bd-carousel-status]');
      var hoverMedia = window.matchMedia('(hover: hover)');
      var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      var realSlideCount = realSlides.length;
      var infiniteLoop = realSlideCount > 1;
      var autoplayEnabled = root.dataset.autoplay === 'true' && realSlideCount > 1 && !reducedMotion.matches;
      var autoplaySpeed = parseInt(root.dataset.autoplaySpeed || '5000', 10);
      var slides = realSlides.slice();
      var activeIndex = infiniteLoop ? 1 : 0;
      var activeRealIndex = 0;
      var autoplayTimer = null;
      var pausedByHover = false;
      var pausedByFocus = false;
      var touchStartX = 0;
      var touchCurrentX = 0;
      var touchActive = false;
      var swipeThreshold = 42;
      var transitionLock = false;
      var syncUiResetFrame = null;

      function getWrappedIndex(index) {
        if (realSlideCount === 0) return 0;
        if (index < 0) return realSlideCount - 1;
        if (index >= realSlideCount) return 0;
        return index;
      }

      function cloneBoundarySlides() {
        if (!infiniteLoop) return;

        var firstClone = realSlides[0].cloneNode(true);
        var lastClone = realSlides[realSlides.length - 1].cloneNode(true);

        firstClone.dataset.bdCarouselClone = 'true';
        lastClone.dataset.bdCarouselClone = 'true';
        firstClone.id = 'bd-carousel-slide-{{ section.id }}-clone-first';
        lastClone.id = 'bd-carousel-slide-{{ section.id }}-clone-last';
        firstClone.setAttribute('aria-hidden', 'true');
        lastClone.setAttribute('aria-hidden', 'true');
        firstClone.classList.remove('is-active');
        lastClone.classList.remove('is-active');

        track.insertBefore(lastClone, track.firstChild);
        track.appendChild(firstClone);
        slides = Array.prototype.slice.call(root.querySelectorAll('[data-bd-carousel-slide]'));
      }

      function setTransform(index, animate) {
        if (typeof animate === 'undefined') animate = true;
        if (!animate) {
          track.style.transition = 'none';
        } else {
          track.style.transition = '';
        }
        track.style.transform = 'translateX(' + (-index * 100) + '%)';
        if (!animate) {
          track.offsetHeight;
          track.style.transition = '';
        }
      }

      function updateUi() {
        slides.forEach(function(slide, index) {
          var isActive = index === activeIndex;
          slide.classList.toggle('is-active', isActive);
          slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });

        dots.forEach(function(dot, index) {
          var isActive = index === activeRealIndex;
          dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        if (status) {
          status.textContent = 'Slide ' + (activeRealIndex + 1) + ' of ' + realSlideCount;
        }
      }

      function setSyncingUiState(isSyncing) {
        if (syncUiResetFrame) {
          window.cancelAnimationFrame(syncUiResetFrame);
          syncUiResetFrame = null;
        }

        root.classList.toggle('bd-carousel--syncing', isSyncing);

        if (isSyncing) {
          syncUiResetFrame = window.requestAnimationFrame(function() {
            syncUiResetFrame = window.requestAnimationFrame(function() {
              root.classList.remove('bd-carousel--syncing');
              syncUiResetFrame = null;
            });
          });
        }
      }

      function stopAutoplay() {
        if (!autoplayTimer) return;
        window.clearTimeout(autoplayTimer);
        autoplayTimer = null;
      }

      function shouldPauseAutoplay() {
        return pausedByHover || pausedByFocus;
      }

      function startAutoplay() {
        stopAutoplay();
        if (!autoplayEnabled || shouldPauseAutoplay()) return;
        autoplayTimer = window.setTimeout(function() {
          stepTo(1, { userInitiated: false });
        }, autoplaySpeed);
      }

      function syncInfinitePosition() {
        var didSync = false;
        if (!infiniteLoop) return;
        if (activeIndex === 0) {
          activeIndex = realSlideCount;
          setTransform(activeIndex, false);
          didSync = true;
        } else if (activeIndex === slides.length - 1) {
          activeIndex = 1;
          setTransform(activeIndex, false);
          didSync = true;
        }
        return didSync;
      }

      function goToRealIndex(nextRealIndex, options) {
        options = options || {};
        if (realSlideCount < 2 || transitionLock) return;
        activeRealIndex = getWrappedIndex(nextRealIndex);
        transitionLock = !reducedMotion.matches;
        activeIndex = infiniteLoop ? activeRealIndex + 1 : activeRealIndex;
        setTransform(activeIndex, !reducedMotion.matches);
        updateUi();
        if (options.userInitiated !== false) {
          startAutoplay();
        } else {
          startAutoplay();
        }
        if (reducedMotion.matches) {
          transitionLock = false;
        }
      }

      function stepTo(direction, options) {
        options = options || {};
        if (realSlideCount < 2 || transitionLock) return;
        transitionLock = !reducedMotion.matches;
        activeIndex += direction;
        activeRealIndex = getWrappedIndex(activeRealIndex + direction);
        setTransform(activeIndex, !reducedMotion.matches);
        updateUi();
        startAutoplay();

        if (reducedMotion.matches) {
          setSyncingUiState(syncInfinitePosition());
          updateUi();
          transitionLock = false;
        }
      }

      function onPrevClick() {
        stepTo(-1, { userInitiated: true });
      }

      function onNextClick() {
        stepTo(1, { userInitiated: true });
      }

      function onKeydown(event) {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          onPrevClick();
        } else if (event.key === 'ArrowRight') {
          event.preventDefault();
          onNextClick();
        }
      }

      function onTouchStart(event) {
        if (!event.touches || event.touches.length !== 1) return;
        touchActive = true;
        touchStartX = event.touches[0].clientX;
        touchCurrentX = touchStartX;
        stopAutoplay();
      }

      function onTouchMove(event) {
        if (!touchActive || !event.touches || event.touches.length !== 1) return;
        touchCurrentX = event.touches[0].clientX;
      }

      function onTouchEnd() {
        if (!touchActive) return;
        var deltaX = touchCurrentX - touchStartX;
        touchActive = false;

        if (Math.abs(deltaX) >= swipeThreshold) {
          if (deltaX > 0) {
            onPrevClick();
          } else {
            onNextClick();
          }
        } else {
          startAutoplay();
        }
      }

      if (prevButton) prevButton.addEventListener('click', onPrevClick);
      if (nextButton) nextButton.addEventListener('click', onNextClick);

      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          var nextIndex = parseInt(dot.getAttribute('data-slide-index') || '0', 10);
          goToRealIndex(nextIndex, { userInitiated: true });
        });
      });

      root.addEventListener('keydown', onKeydown);
      viewport.addEventListener('touchstart', onTouchStart, { passive: true });
      viewport.addEventListener('touchmove', onTouchMove, { passive: true });
      viewport.addEventListener('touchend', onTouchEnd);
      viewport.addEventListener('touchcancel', onTouchEnd);
      track.addEventListener('transitionend', function(event) {
        if (event.target !== track) return;
        setSyncingUiState(syncInfinitePosition());
        updateUi();
        transitionLock = false;
      });

      root.addEventListener('focusin', function() {
        pausedByFocus = true;
        stopAutoplay();
      });

      root.addEventListener('focusout', function() {
        window.setTimeout(function() {
          pausedByFocus = root.contains(document.activeElement);
          if (!pausedByFocus) startAutoplay();
        }, 0);
      });

      if (hoverMedia.matches) {
        root.addEventListener('mouseenter', function() {
          pausedByHover = true;
          stopAutoplay();
        });

        root.addEventListener('mouseleave', function() {
          pausedByHover = false;
          startAutoplay();
        });
      }

      if (typeof reducedMotion.addEventListener === 'function') {
        reducedMotion.addEventListener('change', function(event) {
          autoplayEnabled = root.dataset.autoplay === 'true' && slides.length > 1 && !event.matches;
          if (event.matches) {
            stopAutoplay();
          } else {
            startAutoplay();
          }
        });
      }

      document.addEventListener('shopify:block:select', function(event) {
        var target = event.target;
        if (!target || !root.contains(target)) return;
        var block = target.closest('[data-bd-carousel-slide]');
        if (!block) return;
        var nextIndex = parseInt(block.getAttribute('data-slide-index') || '0', 10);
        goToRealIndex(nextIndex, { userInitiated: true });
      });

      window.addEventListener('resize', function() {
        setTransform(activeIndex, false);
      });

      cloneBoundarySlides();
      updateUi();
      setTransform(activeIndex, false);
      startAutoplay();
    })();
  </script>
</section>

