  </style>

  <div class="bd-carousel__shell {% if bd_carousel_use_page_width %}bd-carousel__shell--page page-width{% elsif bd_carousel_use_custom_width %}bd-carousel__shell--custom bd-carousel__shell--full{% else %}bd-carousel__shell--full{% endif %}">
    <div class="bd-carousel__frame">
      <div class="bd-carousel__viewport" data-bd-carousel-viewport>
        <div class="bd-carousel__track" data-bd-carousel-track>
