{%- liquid
  assign trust_enabled = section.settings.enable_section
  assign mobile_behavior = section.settings.mobile_behavior | default: 'scroll'
  assign show_card_1 = section.settings.show_card_1
  assign show_card_2 = section.settings.show_card_2
  assign show_card_3 = section.settings.show_card_3
  assign show_card_4 = section.settings.show_card_4
  assign show_fifth_card = section.settings.show_fifth_card
  assign card_radius = section.settings.card_radius | default: 'pill'
  assign content_alignment = section.settings.content_alignment | default: 'center'
  assign icon_position = section.settings.icon_position | default: 'before'
  assign use_theme_font = section.settings.use_theme_font
  assign width_mode = section.settings.width_mode | default: 'page'
  assign rotate_interval = section.settings.rotate_interval | default: 4
  assign custom_width_desktop = section.settings.custom_width_desktop | default: 1320
  assign custom_width_mobile = section.settings.custom_width_mobile | default: 360
  assign font_size_desktop = section.settings.font_size_desktop | default: 13
  assign font_size_mobile = section.settings.font_size_mobile | default: 12
  assign font_weight = section.settings.font_weight | default: '500'
  assign enable_sticky_desktop = section.settings.enable_sticky_desktop
  assign enable_sticky_mobile = section.settings.enable_sticky_mobile
  assign sticky_top_offset_desktop = section.settings.sticky_top_offset_desktop | default: 0
  assign sticky_top_offset_mobile = section.settings.sticky_top_offset_mobile | default: 0

  assign card_1_text = section.settings.card_1_text | strip
  assign card_2_text = section.settings.card_2_text | strip
  assign card_3_text = section.settings.card_3_text | strip
  assign card_4_text = section.settings.card_4_text | strip
  assign card_5_text = section.settings.card_5_text | strip
  assign card_1_icon = section.settings.card_1_icon | strip
  assign card_2_icon = section.settings.card_2_icon | strip
  assign card_3_icon = section.settings.card_3_icon | strip
  assign card_4_icon = section.settings.card_4_icon | strip
  assign card_5_icon = section.settings.card_5_icon | strip
-%}

{%- if trust_enabled -%}
  {%- style -%}
    #shopify-section-{{ section.id }} {
      margin: 0;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards {
      --bd-trust-section-bg: {{ section.settings.section_bg_color }};
      --bd-trust-card-bg: {{ section.settings.card_bg_color }};
      --bd-trust-card-border: {{ section.settings.card_border_color }};
      --bd-trust-text-color: {{ section.settings.text_color }};
      --bd-trust-card-radius: {% case card_radius %}{% when 'soft' %}0.8rem{% when 'rounded' %}1.15rem{% else %}999px{% endcase %};
      --bd-trust-font-size-desktop: {{ font_size_desktop }}px;
      --bd-trust-font-size-mobile: {{ font_size_mobile }}px;
      --bd-trust-font-size: var(--bd-trust-font-size-desktop);
      --bd-trust-font-weight: {{ font_weight }};
      --bd-trust-line-height: 1.2;
      --bd-trust-content-justify: {% case content_alignment %}{% when 'left' %}flex-start{% when 'right' %}flex-end{% else %}center{% endcase %};
      --bd-trust-content-text-align: {% case content_alignment %}{% when 'left' %}left{% when 'right' %}right{% else %}center{% endcase %};
      --bd-trust-sticky-top-desktop: {{ sticky_top_offset_desktop }}px;
      --bd-trust-sticky-top-mobile: {{ sticky_top_offset_mobile }}px;
      color: var(--bd-trust-text-color, rgb(var(--color-foreground)));
      margin: 0;
      padding: 0.35rem 0;
      position: relative;
      z-index: 0;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards__inner {
      background: var(--bd-trust-section-bg, rgb(var(--color-background)));
      border-radius: 1.2rem;
      box-sizing: border-box;
      margin: 0 auto;
      overflow: hidden;
      padding: 0.4rem 0.6rem;
      margin: 0 auto;
      width: 100%;
      {% if width_mode == 'custom' %}
        width: min(calc(100% - 2rem), {{ custom_width_desktop }}px);
        max-width: {{ custom_width_desktop }}px;
      {% elsif width_mode == 'page' %}
        max-width: var(--page-width);
      {% elsif width_mode == 'full' %}
        max-width: none;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards__track {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      flex-wrap: nowrap;
      margin: 0;
      max-width: 100%;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bd-trust-card {
      align-items: center;
      background: var(--bd-trust-card-bg, rgb(var(--color-background)));
      border: 1px solid var(--bd-trust-card-border, rgba(var(--color-foreground), 0.08));
      border-radius: var(--bd-trust-card-radius);
      box-shadow: 0 1px 2px rgba(var(--color-foreground), 0.03);
      color: var(--bd-trust-text-color, rgb(var(--color-foreground)));
      display: inline-flex;
      flex: 1 1 0;
      font-size: var(--bd-trust-font-size);
      {% if use_theme_font %}
        font-family: var(--font-body-family);
        font-style: var(--font-body-style);
      {% endif %}
      font-weight: var(--bd-trust-font-weight);
      line-height: var(--bd-trust-line-height);
      letter-spacing: 0;
      margin: 0;
      min-width: 0;
      min-height: 3.3rem;
      padding: 0.5rem 0.85rem;
      text-decoration: none;
      transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease, background-color 150ms ease;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .bd-trust-card__link {
      color: inherit;
      display: inline-flex;
      align-items: center;
      justify-content: stretch;
      text-decoration: none;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .bd-trust-card__content {
      align-items: center;
      display: flex;
      gap: 0.55rem;
      justify-content: var(--bd-trust-content-justify);
      max-width: 100%;
      min-width: 0;
      text-align: var(--bd-trust-content-text-align);
      width: 100%;
    }

    #shopify-section-{{ section.id }} .bd-trust-card__icon {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1em;
      line-height: 1;
      transform: translateY(-0.02em);
    }

    #shopify-section-{{ section.id }} .bd-trust-card__text {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="center"] .bd-trust-card__content {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 0.55rem;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="center"] .bd-trust-card__icon--before {
      grid-column: 1;
      justify-self: end;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="center"] .bd-trust-card__text {
      grid-column: 2;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="center"] .bd-trust-card__icon--after {
      grid-column: 3;
      justify-self: start;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="left"] .bd-trust-card__content {
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-content-alignment="right"] .bd-trust-card__content {
      justify-content: flex-end;
    }

    #shopify-section-{{ section.id }} .bd-trust-card.bd-trust-card--linked:hover,
    #shopify-section-{{ section.id }} .bd-trust-card.bd-trust-card--linked:focus-within {
      border-color: rgba(var(--color-foreground), 0.12);
      box-shadow: 0 3px 10px rgba(var(--color-foreground), 0.05);
      color: var(--bd-trust-text-color, rgb(var(--color-foreground)));
      outline: none;
      transform: translateY(-1px);
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .bd-trust-bar-cards {
        --bd-trust-font-size: var(--bd-trust-font-size-mobile);
        padding: 0.35rem 0;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards__inner {
        border-radius: 1rem;
        padding: 0.4rem 0.45rem;
        {% if width_mode == 'custom' %}
          width: min(100%, {{ custom_width_mobile }}px);
          max-width: {{ custom_width_mobile }}px;
        {% elsif width_mode == 'page' %}
          max-width: 100%;
        {% elsif width_mode == 'full' %}
          max-width: none;
        {% endif %}
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards__track {
        justify-content: flex-start;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="scroll"] .bd-trust-bar-cards__track {
        overflow-x: auto;
        overflow-y: hidden;
        padding: 0;
        scroll-behavior: smooth;
        scroll-snap-type: x proximity;
        -ms-overflow-style: none;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="scroll"] .bd-trust-bar-cards__track::-webkit-scrollbar {
        display: none;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="scroll"] .bd-trust-card {
        flex: 0 0 auto;
        min-width: min(26rem, calc(100vw - 4rem));
        width: min(26rem, calc(100vw - 4rem));
        max-width: calc(100vw - 4rem);
        scroll-snap-align: start;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="rotate"] .bd-trust-bar-cards__track {
        display: block;
        overflow: hidden;
        padding: 0;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="rotate"] .bd-trust-card {
        box-sizing: border-box;
        display: none;
        flex: 0 0 auto;
        justify-content: center;
        margin: 0 auto;
        max-width: none;
        min-width: 0;
        width: 100%;
      }

      #shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="rotate"] .bd-trust-card.is-active {
        display: inline-flex;
      }
    }

    @media screen and (min-width: 750px) {
      {% if enable_sticky_desktop %}
        #shopify-section-{{ section.id }} .bd-trust-bar-cards {
          position: sticky;
          top: var(--bd-trust-sticky-top-desktop);
          z-index: 20;
        }
      {% endif %}
    }

    @media screen and (max-width: 749px) {
      {% if enable_sticky_mobile %}
        #shopify-section-{{ section.id }} .bd-trust-bar-cards {
          position: sticky;
          top: var(--bd-trust-sticky-top-mobile);
          z-index: 20;
        }
      {% endif %}
    }
  {%- endstyle -%}

    <div
      class="bd-trust-bar-cards"
      data-section-id="{{ section.id }}"
      data-mobile-behavior="{{ mobile_behavior }}"
      data-content-alignment="{{ content_alignment }}"
    >
    <div class="bd-trust-bar-cards__inner">
      <div class="bd-trust-bar-cards__track">
      {%- if show_card_1 and card_1_text != blank -%}
        <div class="bd-trust-card{% if section.settings.card_1_link != blank %} bd-trust-card--linked{% endif %}{% if mobile_behavior == 'rotate' %} is-active{% endif %}">
          {%- if section.settings.card_1_link != blank -%}
            <a class="bd-trust-card__link" href="{{ section.settings.card_1_link }}">
              <span class="bd-trust-card__content">
                {%- if icon_position == 'before' and card_1_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_1_icon | escape }}</span>{%- endif -%}
                <span class="bd-trust-card__text">{{ card_1_text | escape }}</span>
                {%- if icon_position == 'after' and card_1_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_1_icon | escape }}</span>{%- endif -%}
              </span>
            </a>
          {%- else -%}
            <span class="bd-trust-card__content">
              {%- if icon_position == 'before' and card_1_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_1_icon | escape }}</span>{%- endif -%}
              <span class="bd-trust-card__text">{{ card_1_text | escape }}</span>
              {%- if icon_position == 'after' and card_1_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_1_icon | escape }}</span>{%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_card_2 and card_2_text != blank -%}
        <div class="bd-trust-card{% if section.settings.card_2_link != blank %} bd-trust-card--linked{% endif %}">
          {%- if section.settings.card_2_link != blank -%}
            <a class="bd-trust-card__link" href="{{ section.settings.card_2_link }}">
              <span class="bd-trust-card__content">
                {%- if icon_position == 'before' and card_2_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_2_icon | escape }}</span>{%- endif -%}
                <span class="bd-trust-card__text">{{ card_2_text | escape }}</span>
                {%- if icon_position == 'after' and card_2_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_2_icon | escape }}</span>{%- endif -%}
              </span>
            </a>
          {%- else -%}
            <span class="bd-trust-card__content">
              {%- if icon_position == 'before' and card_2_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_2_icon | escape }}</span>{%- endif -%}
              <span class="bd-trust-card__text">{{ card_2_text | escape }}</span>
              {%- if icon_position == 'after' and card_2_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_2_icon | escape }}</span>{%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_card_3 and card_3_text != blank -%}
        <div class="bd-trust-card{% if section.settings.card_3_link != blank %} bd-trust-card--linked{% endif %}">
          {%- if section.settings.card_3_link != blank -%}
            <a class="bd-trust-card__link" href="{{ section.settings.card_3_link }}">
              <span class="bd-trust-card__content">
                {%- if icon_position == 'before' and card_3_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_3_icon | escape }}</span>{%- endif -%}
                <span class="bd-trust-card__text">{{ card_3_text | escape }}</span>
                {%- if icon_position == 'after' and card_3_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_3_icon | escape }}</span>{%- endif -%}
              </span>
            </a>
          {%- else -%}
            <span class="bd-trust-card__content">
              {%- if icon_position == 'before' and card_3_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_3_icon | escape }}</span>{%- endif -%}
              <span class="bd-trust-card__text">{{ card_3_text | escape }}</span>
              {%- if icon_position == 'after' and card_3_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_3_icon | escape }}</span>{%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_card_4 and card_4_text != blank -%}
        <div class="bd-trust-card{% if section.settings.card_4_link != blank %} bd-trust-card--linked{% endif %}">
          {%- if section.settings.card_4_link != blank -%}
            <a class="bd-trust-card__link" href="{{ section.settings.card_4_link }}">
              <span class="bd-trust-card__content">
                {%- if icon_position == 'before' and card_4_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_4_icon | escape }}</span>{%- endif -%}
                <span class="bd-trust-card__text">{{ card_4_text | escape }}</span>
                {%- if icon_position == 'after' and card_4_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_4_icon | escape }}</span>{%- endif -%}
              </span>
            </a>
          {%- else -%}
            <span class="bd-trust-card__content">
              {%- if icon_position == 'before' and card_4_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_4_icon | escape }}</span>{%- endif -%}
              <span class="bd-trust-card__text">{{ card_4_text | escape }}</span>
              {%- if icon_position == 'after' and card_4_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_4_icon | escape }}</span>{%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_fifth_card and card_5_text != blank -%}
        <div class="bd-trust-card{% if section.settings.card_5_link != blank %} bd-trust-card--linked{% endif %}">
          {%- if section.settings.card_5_link != blank -%}
            <a class="bd-trust-card__link" href="{{ section.settings.card_5_link }}">
              <span class="bd-trust-card__content">
                {%- if icon_position == 'before' and card_5_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_5_icon | escape }}</span>{%- endif -%}
                <span class="bd-trust-card__text">{{ card_5_text | escape }}</span>
                {%- if icon_position == 'after' and card_5_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_5_icon | escape }}</span>{%- endif -%}
              </span>
            </a>
          {%- else -%}
            <span class="bd-trust-card__content">
              {%- if icon_position == 'before' and card_5_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--before">{{ card_5_icon | escape }}</span>{%- endif -%}
              <span class="bd-trust-card__text">{{ card_5_text | escape }}</span>
              {%- if icon_position == 'after' and card_5_icon != blank -%}<span class="bd-trust-card__icon bd-trust-card__icon--after">{{ card_5_icon | escape }}</span>{%- endif -%}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
      </div>
    </div>
  </div>

  {%- if mobile_behavior == 'rotate' -%}
    <script>
      (() => {
        const sectionRoot = document.querySelector('#shopify-section-{{ section.id }} .bd-trust-bar-cards[data-mobile-behavior="rotate"]');
        if (!sectionRoot) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const cards = Array.from(sectionRoot.querySelectorAll('.bd-trust-card'));
        if (cards.length < 2) return;

        let index = cards.findIndex((card) => card.classList.contains('is-active'));
        if (index < 0) index = 0;

        const setActive = (nextIndex) => {
          cards.forEach((card, cardIndex) => {
            card.classList.toggle('is-active', cardIndex === nextIndex);
            card.setAttribute('aria-hidden', cardIndex === nextIndex ? 'false' : 'true');
          });
        };

        setActive(index);

        if (window.matchMedia('(min-width: 750px)').matches) return;

        window.setInterval(() => {
          if (!document.body.contains(sectionRoot)) return;
          if (!window.matchMedia('(max-width: 749px)').matches) return;
          index = (index + 1) % cards.length;
          setActive(index);
        }, {{ rotate_interval | times: 1000 }});
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Trust Bar Cards",
  "class": "bd-trust-bar-cards-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable trust bar",
      "default": true
    },
    {
      "type": "select",
      "id": "mobile_behavior",
      "label": "Mobile behavior",
      "default": "scroll",
      "options": [
        { "value": "scroll", "label": "Scroll" },
        { "value": "rotate", "label": "Rotate" }
      ]
    },
    {
      "type": "range",
      "id": "rotate_interval",
      "label": "Rotate interval",
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_desktop",
      "label": "Enable sticky on desktop",
      "default": false
    },
    {
      "type": "range",
      "id": "sticky_top_offset_desktop",
      "label": "Sticky top offset desktop",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_mobile",
      "label": "Enable sticky on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "sticky_top_offset_mobile",
      "label": "Sticky top offset mobile",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Full width" },
        { "value": "custom", "label": "Custom width" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width_desktop",
      "label": "Custom desktop width",
      "min": 1200,
      "max": 1600,
      "step": 4,
      "unit": "px",
      "default": 1320
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "Custom mobile width",
      "min": 280,
      "max": 480,
      "step": 2,
      "unit": "px",
      "default": 360
    },
    {
      "type": "checkbox",
      "id": "show_card_1",
      "label": "Show card 1",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_2",
      "label": "Show card 2",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_3",
      "label": "Show card 3",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_4",
      "label": "Show card 4",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_fifth_card",
      "label": "Show card 5",
      "default": true
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Card content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "default": "before",
      "options": [
        { "value": "before", "label": "Before text" },
        { "value": "after", "label": "After text" }
      ]
    },
    {
      "type": "text",
      "id": "card_1_icon",
      "label": "Card 1 icon",
      "default": "❤️"
    },
