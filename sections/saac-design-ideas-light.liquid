    },
    {
      "type": "text",
      "id": "mid_primary_label",
      "label": "Primary button label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "mid_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "mid_secondary_label",
      "label": "Secondary button label",
      "default": "Start Designing"
    },
    {
      "type": "url",
      "id": "mid_secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "text",
      "id": "bottom_heading",
