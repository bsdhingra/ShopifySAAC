    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Design Ideas & Inspiration"
    },
    {
      "type": "richtext",
      "id": "hero_text",
      "label": "Text",
      "default": "<p>Browse ideas or start your own — customize any design in minutes with live preview on supported products.</p>"
    },
    {
      "type": "text",
      "id": "hero_button_label",
      "label": "Button label",
      "default": "Start Designing Now"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Shared links"
    },
    {
      "type": "text",
      "id": "start_designing_label",
      "label": "Start designing label",
      "default": "Start Designing"
    },
    {
      "type": "url",
      "id": "start_designing_link",
      "label": "Start designing link"
    },
    {
      "type": "url",
      "id": "customize_idea_link",
      "label": "Customize idea link"
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
