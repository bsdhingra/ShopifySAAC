{%- if cart != empty -%}
  {%- for item in cart.items -%}
    <div id="cart-notification-product-{{ item.key }}" class="cart-item">
      {%- if item.image -%}
        <div class="cart-notification-product__image global-media-settings">
          <img
            src="{{ item.image | image_url: width: 140 }}"
            alt="{{ item.image.alt | escape }}"
            width="70"
            height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
      <div>
        {%- if settings.show_vendor -%}
          <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
        {%- endif -%}
        <h3 class="cart-notification-product__name h4">{{ item.product.title | escape }}</h3>

        {%- assign bd_front_proof_url = item.properties['_Front Proof Mockup URL'] -%}
        {%- assign bd_back_proof_url = item.properties['_Back Proof Mockup URL'] -%}
        {%- assign bd_proof_url = item.properties['Proof Mockup URL'] -%}
        {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url == blank -%}
          {%- assign bd_proof_url = item.properties['_Proof Mockup URL'] -%}
        {%- endif -%}
        {%- assign bd_proof_notice = item.properties['_Proof Notice'] -%}
        {%- assign bd_upload_notice = item.properties['_Upload Notice'] -%}
        {%- assign bd_upload_url = item.properties['Design 1 URL'] -%}
        {%- assign bd_upload_url_back = item.properties['Design 2 URL'] -%}
        {%- if bd_upload_url_back == blank -%}
          {%- assign bd_upload_url_back = item.properties['_Design 2 URL'] -%}
        {%- endif -%}
        {%- assign bd_front_upload_state = item.properties['_Front Upload State'] | default: 'none' -%}
        {%- assign bd_back_upload_state = item.properties['_Back Upload State'] | default: 'none' -%}
        {%- assign bd_front_upload_notice = item.properties['_Front Upload Notice'] -%}
        {%- assign bd_back_upload_notice = item.properties['_Back Upload Notice'] -%}
        {%- assign bd_preview_flow = item.properties['_Preview Flow'] | default: '' -%}
        {%- assign bd_is_proof_gated = false -%}
        {%- if bd_preview_flow == 'proof-gated' -%}
          {%- assign bd_is_proof_gated = true -%}
        {%- endif -%}
        {%- assign bd_upload_fallback_notice = "Your image is larger than 10MB, but no worries-you can still edit and preview your design. After placing your order, just email your image to info@sarvsartsandcrafts.com, and we'll handle the proof for you." -%}
        {%- assign customization_text = item.properties['Customization text'] -%}

        <dl>
          {%- unless item.product.has_only_default_variant -%}
            {%- for option in item.options_with_values -%}
              <div class="product-option">
                <dt>{{ option.name }}:</dt>
                <dd>{{ option.value }}</dd>
              </div>
            {%- endfor -%}
          {%- endunless -%}
          {%- if customization_text != blank -%}
            <div class="product-option">
              <dt>Customization:</dt>
              <dd>{{ customization_text }}</dd>
            </div>
          {%- endif -%}
        </dl>

        {%- if bd_front_proof_url != blank or bd_back_proof_url != blank or bd_proof_url != blank or bd_upload_url != blank or bd_upload_url_back != blank -%}
          <div class="bd-cart-notification-media">
            {%- if bd_front_proof_url != blank -%}
              <a href="{{ bd_front_proof_url }}" target="_blank" rel="noopener" class="bd-cart-notification-media__item">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_front_proof_url | escape }}"
                  alt="Front proof"
                  width="88"
                  height="88"
                  loading="lazy"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span>Front preview</span>
              </a>
            {%- endif -%}
            {%- if bd_back_proof_url != blank -%}
              <a href="{{ bd_back_proof_url }}" target="_blank" rel="noopener" class="bd-cart-notification-media__item">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_back_proof_url | escape }}"
                  alt="Back proof"
                  width="88"
                  height="88"
                  loading="lazy"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span>Back preview</span>
              </a>
            {%- endif -%}
            {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url != blank -%}
              <a href="{{ bd_proof_url }}" target="_blank" rel="noopener" class="bd-cart-notification-media__item">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_proof_url | escape }}"
                  alt="Design proof"
                  width="88"
                  height="88"
                  loading="lazy"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span>Design preview</span>
              </a>
            {%- endif -%}
            {%- if bd_upload_url != blank -%}
              <a href="{{ bd_upload_url }}" target="_blank" rel="noopener" class="bd-cart-notification-media__item">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_upload_url | escape }}"
                  alt="Uploaded design"
                  width="88"
                  height="88"
                  loading="lazy"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span>Front uploaded image</span>
              </a>
            {%- endif -%}
            {%- if bd_upload_url_back != blank -%}
              <a href="{{ bd_upload_url_back }}" target="_blank" rel="noopener" class="bd-cart-notification-media__item">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_upload_url_back | escape }}"
                  alt="Back uploaded design"
                  width="88"
                  height="88"
                  loading="lazy"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span>Back uploaded image</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url == blank and bd_proof_notice != blank -%}
          <div class="bd-cart-notification-note">
            {{ bd_proof_notice }}
          </div>
        {%- endif -%}

        {%- if bd_front_upload_state == 'fallback' and bd_front_upload_notice != blank -%}
          <div class="bd-cart-notification-note">
            {%- if bd_back_proof_url != blank or bd_upload_url_back != blank -%}
              <div class="bd-cart-notification-note__label">Front uploaded image</div>
            {%- endif -%}
            {{ bd_front_upload_notice }}
          </div>
        {%- endif -%}

        {%- if bd_back_upload_state == 'fallback' and bd_back_upload_notice != blank -%}
          <div class="bd-cart-notification-note">
            <div class="bd-cart-notification-note__label">Back uploaded image</div>
            {{ bd_back_upload_notice }}
          </div>
        {%- endif -%}

        {%- if item.selling_plan_allocation != null -%}
          <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
{%- endif -%}
