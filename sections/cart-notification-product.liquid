{%- if cart != empty -%}
  {%- for item in cart.items -%}
    <div id="cart-notification-product-{{ item.key }}" class="cart-item">
      {%- if item.image -%}
        <div class="cart-notification-product__image global-media-settings">
          <img
            src="{{ item.image | image_url: width: 140 }}"
            alt="{{ item.image.alt | escape }}"
            width="70"
            height="{{ 70 | divided_by: item.image.aspect_ratio | ceil }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
      <div>
        {%- if settings.show_vendor -%}
          <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
        {%- endif -%}
        <h3 class="cart-notification-product__name h4">{{ item.product.title | escape }}</h3>

        {%- assign bd_front_proof_url = item.properties['_Front Proof Mockup URL'] -%}
        {%- assign bd_back_proof_url = item.properties['_Back Proof Mockup URL'] -%}
        {%- assign bd_proof_url = item.properties['Proof Mockup URL'] -%}
        {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url == blank -%}
          {%- assign bd_proof_url = item.properties['_Proof Mockup URL'] -%}
        {%- endif -%}
        {%- assign bd_proof_notice = item.properties['_Proof Notice'] -%}
        {%- assign bd_upload_notice = item.properties['_Upload Notice'] -%}
        {%- assign bd_upload_url = item.properties['Design 1 URL'] -%}
        {%- assign bd_upload_url_back = item.properties['Design 2 URL'] -%}
        {%- assign bd_upload_fallback_notice = "Your image is larger than 10MB, but no worries-you can still edit and preview your design. After placing your order, just email your image to info@sarvsartsandcrafts.com, and we'll handle the proof for you." -%}
        {%- assign customization_text = item.properties['Customization text'] -%}

        <dl>
          {%- unless item.product.has_only_default_variant -%}
            {%- for option in item.options_with_values -%}
              <div class="product-option">
                <dt>{{ option.name }}:</dt>
                <dd>{{ option.value }}</dd>
              </div>
            {%- endfor -%}
          {%- endunless -%}
          {%- if customization_text != blank -%}
            <div class="product-option">
              <dt>Customization:</dt>
              <dd>{{ customization_text }}</dd>
            </div>
          {%- endif -%}
        </dl>

        {%- if bd_front_proof_url != blank or bd_back_proof_url != blank or bd_proof_url != blank -%}
          <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;">
            {%- if bd_front_proof_url != blank -%}
              <a href="{{ bd_front_proof_url }}" target="_blank" rel="noopener" style="display:block; width:88px; text-decoration:none; color:inherit;">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_front_proof_url | escape }}"
                  alt="Front proof"
                  width="88"
                  height="88"
                  loading="lazy"
                  style="display:block; width:88px; height:auto; border-radius:8px; border:1px solid rgba(0,0,0,.12);"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span style="display:block; margin-top:4px; font-size:12px; opacity:.85;">Front preview</span>
              </a>
            {%- endif -%}
            {%- if bd_back_proof_url != blank -%}
              <a href="{{ bd_back_proof_url }}" target="_blank" rel="noopener" style="display:block; width:88px; text-decoration:none; color:inherit;">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_back_proof_url | escape }}"
                  alt="Back proof"
                  width="88"
                  height="88"
                  loading="lazy"
                  style="display:block; width:88px; height:auto; border-radius:8px; border:1px solid rgba(0,0,0,.12);"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span style="display:block; margin-top:4px; font-size:12px; opacity:.85;">Back preview</span>
              </a>
            {%- endif -%}
            {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url != blank -%}
              <a href="{{ bd_proof_url }}" target="_blank" rel="noopener" style="display:block; width:88px; text-decoration:none; color:inherit;">
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                <img
                  src="{{ bd_proof_url | escape }}"
                  alt="Design proof"
                  width="88"
                  height="88"
                  loading="lazy"
                  style="display:block; width:88px; height:auto; border-radius:8px; border:1px solid rgba(0,0,0,.12);"
                >
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
                <span style="display:block; margin-top:4px; font-size:12px; opacity:.85;">Design preview</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if bd_front_proof_url == blank and bd_back_proof_url == blank and bd_proof_url == blank and bd_proof_notice != blank -%}
          <div style="margin-top:10px; font-size:12px; line-height:1.45; color:rgba(0,0,0,.78);">
            {{ bd_proof_notice }}
          </div>
        {%- endif -%}

        {%- if bd_upload_url != blank -%}
          <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;">
            <a href="{{ bd_upload_url }}" target="_blank" rel="noopener" style="display:block; width:88px; text-decoration:none; color:inherit;">
              {% comment %} theme-check-disable RemoteAsset {% endcomment %}
              <img
                src="{{ bd_upload_url | escape }}"
                alt="Uploaded design"
                width="88"
                height="88"
                loading="lazy"
                style="display:block; width:88px; height:88px; object-fit:cover; border-radius:8px; border:1px solid rgba(0,0,0,.12);"
              >
              {% comment %} theme-check-enable RemoteAsset {% endcomment %}
              <span style="display:block; margin-top:4px; font-size:12px; opacity:.85;">Uploaded image</span>
            </a>
          </div>
        {%- elsif bd_upload_notice != blank -%}
          <div style="margin-top:10px; font-size:12px; line-height:1.45; color:rgba(0,0,0,.78);">
            {%- if bd_back_proof_url != blank or bd_upload_url_back != blank -%}
              <div style="font-size:12px; opacity:.85; margin-bottom:6px;">Front uploaded image</div>
            {%- endif -%}
            {{ bd_upload_notice }}
          </div>
        {%- elsif bd_proof_url != blank or bd_front_proof_url != blank or bd_back_proof_url != blank or bd_proof_notice != blank -%}
          <div style="margin-top:10px; font-size:12px; line-height:1.45; color:rgba(0,0,0,.78);">
            {%- if bd_back_proof_url != blank or bd_upload_url_back != blank -%}
              <div style="font-size:12px; opacity:.85; margin-bottom:6px;">Front uploaded image</div>
            {%- endif -%}
            {{ bd_upload_fallback_notice }}
          </div>
        {%- endif -%}

        {%- if bd_upload_url_back != blank -%}
          <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;">
            <a href="{{ bd_upload_url_back }}" target="_blank" rel="noopener" style="display:block; width:88px; text-decoration:none; color:inherit;">
              {% comment %} theme-check-disable RemoteAsset {% endcomment %}
              <img
                src="{{ bd_upload_url_back | escape }}"
                alt="Back uploaded design"
                width="88"
                height="88"
                loading="lazy"
                style="display:block; width:88px; height:88px; object-fit:cover; border-radius:8px; border:1px solid rgba(0,0,0,.12);"
              >
              {% comment %} theme-check-enable RemoteAsset {% endcomment %}
              <span style="display:block; margin-top:4px; font-size:12px; opacity:.85;">Back uploaded image</span>
            </a>
          </div>
        {%- elsif bd_back_proof_url != blank and bd_upload_url_back == blank -%}
          <div style="margin-top:10px; font-size:12px; line-height:1.45; color:rgba(0,0,0,.78);">
            <div style="font-size:12px; opacity:.85; margin-bottom:6px;">Back uploaded image</div>
            {{ bd_upload_notice | default: bd_upload_fallback_notice }}
          </div>
        {%- endif -%}

        {%- if item.selling_plan_allocation != null -%}
          <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
{%- endif -%}
